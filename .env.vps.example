# VPS production — .env olarak kopyalayın: cp .env.vps.example .env

# Genel
N8N_PUBLIC_HOST=api.nefalixai.com
EVOLUTION_PUBLIC_HOST=evo.nefalixai.com
V2_SITE_HOST=v2.nefalixai.com
ACME_EMAIL=enes.ceylan190758@gmail.com

# n8n
N8N_PORT=5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_STRONG
N8N_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

# n8n-mcp (opsiyonel — sunucuda MCP gerekmezse MCP_PORT boş bırakılabilir)
MCP_AUTH_TOKEN=CHANGE_ME_openssl_rand_hex_32
MCP_PORT=3000

N8N_API_KEY=

# Supabase — n8n container içinden host.docker.internal (127.0.0.1 değil)
SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Evolution WhatsApp
EVOLUTION_PORT=8080
EVOLUTION_SERVER_URL=https://evo.nefalixai.com
EVOLUTION_API_KEY=CHANGE_ME_openssl_rand_hex_16
EVOLUTION_POSTGRES_PASSWORD=CHANGE_ME_openssl_rand_hex_12

# Estesoft Stella API (Medident) — randevu poll + webhook adapter
ESTESOFT_API_USERNAME=
ESTESOFT_API_KEY=
ESTESOFT_API_PASSWORD=
ESTESOFT_TENANT_ID=
ESTESOFT_STELLA_API_BASE=https://medidentistanbul.stellamedi.com

# WhatsApp ban önleme (tüm gönderimler wf-00 gateway)
WHATSAPP_SEND_ENABLED=false
WHATSAPP_MIN_INTERVAL_SEC=45
WHATSAPP_MAX_PER_HOUR=20
WHATSAPP_MAX_BURST_5MIN=3
ESTESOFT_POLL_MAX_PER_RUN=1
ESTESOFT_POLL_HOURS=24
N8N_URL=http://127.0.0.1:5678
N8N_EMAIL=enkahealthist@gmail.com
N8N_PASSWORD=

# OpenAI — AI workflow'lar
OPENAI_API_KEY=

# Google Places API (New) — tüm klinik Google yorum senkronu
GOOGLE_PLACES_API_KEY=

# PayTR Checkout (opsiyonel - public pricing page Vercel/API tarafı)
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=0
PAYTR_DEBUG=1
PAYTR_OK_URL=https://nefalixai.com/fiyatlar?payment=success
PAYTR_FAIL_URL=https://nefalixai.com/fiyatlar?payment=failed

# Şikayetvar sync (wf-14) — VPS IP 403 alırsa jina proxy otomatik devreye girer
# SIKAYETVAR_USE_JINA=1
# SIKAYETVAR_REQUEST_DELAY_SEC=2
