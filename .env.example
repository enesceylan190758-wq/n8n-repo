# n8n local
N8N_PORT=5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme-strong-password
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
# openssl rand -hex 32
N8N_ENCRYPTION_KEY=replace-with-64-char-hex

# n8n-mcp (https://github.com/czlonkowski/n8n-mcp)
# openssl rand -hex 32
MCP_AUTH_TOKEN=replace-with-at-least-32-character-secret-token
MCP_PORT=3000
LOG_LEVEL=info

# n8n API key — n8n UI → Settings → API → Create API Key
# Local: http://localhost:5678
# Cloud: https://enkahealthisterr.app.n8n.cloud
N8N_API_KEY=

# Cursor MCP (cloud n8n — copy to shell profile or Cursor env)
N8N_API_URL=https://enkahealthisterr.app.n8n.cloud
