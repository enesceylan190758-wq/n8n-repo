# n8n local
N8N_PORT=5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme-strong-password
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
# openssl rand -hex 32
N8N_ENCRYPTION_KEY=replace-with-64-char-hex

# n8n-mcp (https://github.com/czlonkowski/n8n-mcp)
# openssl rand -hex 32
MCP_AUTH_TOKEN=replace-with-at-least-32-character-secret-token
MCP_PORT=3000
LOG_LEVEL=info

# n8n API key — n8n UI → Settings → API → Create API Key
# Local: http://localhost:5678
# Cloud: https://enkahealthisterr.app.n8n.cloud
N8N_API_KEY=

# Cursor MCP (cloud n8n — copy to shell profile or Cursor env)
N8N_API_URL=https://enkahealthisterr.app.n8n.cloud

# Vertex AI / Gemini — GCP trial kredisi (OpenAI yerine)
# GCP Console → IAM → Service Account → Vertex AI User → JSON key
GCP_PROJECT_ID=project-860dace6-d98e-44e1-994
GCP_REGION=europe-west1
VERTEX_GEMINI_MODEL=gemini-2.5-flash
GOOGLE_APPLICATION_CREDENTIALS=.tmp/gcp-service-account.json
# wf-10 code node — refresh-gcp-access-token.py ile güncellenir (saatlik cron)
GCP_ACCESS_TOKEN=

# Google Places API (New) — klinik yorum senkronu (execution/sync-google-reviews.py)
GOOGLE_PLACES_API_KEY=

# Supabase — npx supabase start (local) veya supabase.com (cloud)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Evolution API — WhatsApp pilot (docker-compose.evolution.yml)
# bash execution/setup-evolution.sh
EVOLUTION_PORT=8080
EVOLUTION_MANAGER_PORT=8090
EVOLUTION_SERVER_URL=http://localhost:8080
# openssl rand -hex 16
EVOLUTION_API_KEY=
# openssl rand -hex 12
EVOLUTION_POSTGRES_PASSWORD=
# Düşük NPS / Sentinel özetleri — yönetici WhatsApp (+ olmadan)
CLINIC_MANAGER_WHATSAPP=905491190819

# Estesoft HBYS (Medident) — execution/setup-estesoft-env.sh
ESTESOFT_API_USERNAME=
ESTESOFT_API_KEY=
ESTESOFT_TENANT_ID=
# Estesoft Stella (Medident) — tenant host Swagger'dan
ESTESOFT_STELLA_API_BASE=https://medidentistanbul.stellamedi.com
# API kullanıcı şifresi (apikey header'daki anahtardan FARKLI)
ESTESOFT_API_PASSWORD=

# Vercel / public n8n host
N8N_PUBLIC_HOST=api.nefalixai.com

# Vercel dashboard auth
# DASHBOARD_USERS eski admin hesabı için kalabilir; yeni firmalar dashboard_users tablosunda açılır.
DASHBOARD_SESSION_SECRET=
NEFALIX_INTERNAL_KEY=
N8N_SUPABASE_PROXY_URL=https://api.nefalixai.com/webhook/nefalix/supabase-proxy

# Stripe Checkout (Vercel env)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_SUCCESS_URL=https://nefalixai.com/dashboard#billing
STRIPE_CANCEL_URL=https://nefalixai.com/#pricing

# PayTR Checkout (Vercel env - public pricing page)
# PayTR Magaza Paneli > Bilgi
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=0
PAYTR_DEBUG=1
PAYTR_OK_URL=https://nefalixai.com/fiyatlar?payment=success
PAYTR_FAIL_URL=https://nefalixai.com/fiyatlar?payment=failed
